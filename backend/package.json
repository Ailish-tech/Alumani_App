{
  "name": "alumniconnect-backend",
  "version": "1.0.0",
  "description": "AlumniConnect College Networking Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "create-table": "ts-node scripts/createTable.ts",
    "bulk-sync": "ts-node scripts/bulkSync.ts",
    "start:cluster": "pm2 start ecosystem.config.js --env production",
    "seed-test": "ts-node scripts/seed-test-data.ts",
    "load-test": "npx -y artillery@latest run load-test.yml --output load-test-results.json",
    "load-test:report": "ts-node scripts/load-test-report.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.525.0",
    "@aws-sdk/client-s3": "^3.525.0",
    "@aws-sdk/lib-dynamodb": "^3.525.0",
    "@aws-sdk/node-http-handler": "^3.370.0",
    "@aws-sdk/s3-request-presigner": "^3.525.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "agora-access-token": "^2.0.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "multer": "^2.1.0",
    "pm2": "^7.0.1",
    "redis": "^6.0.0",
    "socket.io": "^4.7.5",
    "typesense": "^3.0.6",
    "uuid": "^9.0.1",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
