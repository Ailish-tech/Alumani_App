# Server
PORT=3000
NODE_ENV=development

# DynamoDB Local
DYNAMO_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=fakeAccessKeyId
AWS_SECRET_ACCESS_KEY=fakeSecretAccessKey

# Firebase (set path when ready; mock mode used when NODE_ENV=development)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# AWS S3
S3_BUCKET=alumniconnect-uploads
S3_REGION=us-east-1

# Agora.io (placeholder — replace with real credentials)
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# Mock Auth (development only)
MOCK_USER_ID=mock-user-001
MOCK_USER_ROLE=STUDENT

# ─── Typesense ────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your_typesense_api_key

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
